# Copy to `.env` and fill in your Supabase project values.
# Both values are safe to expose in the browser (the anon key is protected by RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web3Forms — emails contact/adoption form submissions to your inbox.
# Get a free key at https://web3forms.com (it is safe to expose in the browser).
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
